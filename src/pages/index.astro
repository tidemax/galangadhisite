---
import Base from "../layouts/Base.astro";
import { profile, selectedWork } from "../data/site";

const writingLinks = [
  { label: "Behind the scenes of RRGraph template system ↗", href: "/blog/behind-the-scenes" },
  { label: "How I built cleaner presentation workflows ↗", href: "/blog/cleaner-workflows" },
];

let allMediaGlob = [
  ...Object.entries(
    import.meta.glob("/src/optimized/work/**/*.webp", {
      eager: true,
      query: "?url",
      import: "default",
    })
  ),
  ...Object.entries(
    import.meta.glob("/src/content/work/**/*.mp4", {
      eager: true,
      query: "?url",
      import: "default",
    })
  ),
];

let allMediaFiles = allMediaGlob.map(([path, src]) => {
  const parts = path.split("/");
  const folderName = parts[parts.length - 2];
  const fileName = parts[parts.length - 1];
  const slug = folderName.toLowerCase().replace(/\s+/g, "-");
  
  const lower = fileName.toLowerCase();
  const ratioClass = lower.includes("portrait")
    ? "tile-portrait"
    : lower.includes("landscape")
      ? "tile-landscape"
      : "tile-square";

  return {
    src: String(src),
    name: fileName,
    slug,
    ratioClass,
    isVideo: lower.endsWith(".mp4"),
  };
});

const projectMediaMap: Record<string, typeof allMediaFiles> = {};
for (const item of allMediaFiles) {
  if (!projectMediaMap[item.slug]) {
    projectMediaMap[item.slug] = [];
  }
  projectMediaMap[item.slug].push(item);
}

for (const slug in projectMediaMap) {
  projectMediaMap[slug].sort((a, b) => a.name.localeCompare(b.name, undefined, { numeric: true }));
}

// Custom sort logic for Henlo Branding
if (projectMediaMap["henlo-branding"]) {
  const henloMedia = projectMediaMap["henlo-branding"];
  const idx4 = henloMedia.findIndex((item) => item.name.toLowerCase().startsWith("4 "));
  const idx10 = henloMedia.findIndex((item) => item.name.toLowerCase().startsWith("10 "));
  if (idx4 !== -1 && idx10 !== -1) {
    [henloMedia[idx4], henloMedia[idx10]] = [henloMedia[idx10], henloMedia[idx4]];
  }
}

if (projectMediaMap["logo-&-brand-mark"]?.length >= 6) {
  const logoMedia = projectMediaMap["logo-&-brand-mark"];
  const [sixthItem] = logoMedia.splice(5, 1);
  logoMedia.splice(3, 0, sixthItem);
}

const fallbackClasses = [
  "tile-square",
  "tile-portrait",
  "tile-landscape",
  "tile-square",
  "tile-landscape",
  "tile-square",
  "tile-portrait",
  "tile-landscape",
  "tile-portrait",
];
---

<Base
  title="Galang Saputra | Visual Designer"
  active="home"
  showProfilePhoto={false}
  stickyHeader={true}
  showFooterContact={true}
>
  <section class="section work-section reveal">
      <div class="section-title">Selected Work</div>
      <div class="case-scroll">
        <div class="case-pin" id="case-pin">
          <h3 class="case-pin-title">
            <span id="case-pin-link">{selectedWork[0].title}</span>
          </h3>
          <p class="case-pin-tag" id="case-pin-tag">{selectedWork[0].tags?.join(" · ")}</p>
        </div>

        <div class="grid work-grid">
          {selectedWork.map((work, index) => (
            <article
              class="card work-card reveal"
              data-case-title={work.title}
              data-case-org={work.org}
              data-case-year={work.year}
              data-case-tags={work.tags?.join(" · ") ?? ""}
            >
            {index > 0 && (
              <div class="case-divider">
                <h3>{work.title}</h3>
                <p>{work.tags?.join(" · ")}</p>
              </div>
            )}
            <div class="work-mosaic" aria-hidden="true">
              {projectMediaMap[work.slug] && projectMediaMap[work.slug].length > 0
                ? projectMediaMap[work.slug].map((item, mediaIndex) => (
                    <div class={`tile-item ${item.ratioClass}`}>
                      {item.isVideo ? (
                        <video
                          class="tile-media tile-image"
                          src={item.src}
                          aria-label={`${work.title} video ${mediaIndex + 1}`}
                          muted
                          loop
                          playsinline
                          autoplay
                          preload="metadata"
                        ></video>
                      ) : (
                        <img
                          class="tile-media tile-image"
                          src={item.src}
                          alt={`${work.title} visual ${mediaIndex + 1}`}
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                      <p class="tile-label">{work.title.toUpperCase()} {String(mediaIndex + 1).padStart(2, "0")}.{item.name.split(".").pop()?.toUpperCase()}</p>
                    </div>
                  ))
                : fallbackClasses.map((ratioClass, imageIndex) => (
                    <div class={`tile-item ${ratioClass}`}>
                      <div class="placeholder tile-media"></div>
                      <p class="tile-label">{work.title.toUpperCase()} {String(imageIndex + 1).padStart(2, "0")}.PNG</p>
                    </div>
                  ))}
            </div>
          </article>
        ))}
      </div>
      </div>
  </section>

  <section class="section speak-section reveal">
    <div class="section-title">Speak</div>
    <div class="speak-entry reveal">
      <p class="speak-date">Saturday, 17 June 2023</p>
      <h2 class="speak-title">
        <a href="/speak/from-passion-to-profit">
          From Passion to Profit: Monetizing Creativity in Digital Graphic Design
        </a>
      </h2>
    </div>
  </section>

  <script is:inline>
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.14 }
    );
    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

    const pin = document.getElementById("case-pin");
    const pinTag = document.getElementById("case-pin-tag");
    const pinLink = document.getElementById("case-pin-link");
    const cards = Array.from(document.querySelectorAll(".work-card"));
    let activeCard = cards[0];

    const setPinnedCase = (card) => {
      if (!pin || !pinTag || !pinLink || !card || activeCard === card) return;
      activeCard = card;
      pinLink.textContent = card.dataset.caseTitle || "";
      pinTag.textContent = card.dataset.caseTags || `${card.dataset.caseOrg} · ${card.dataset.caseYear}`;
    };

    let ticking = false;
    const updateActiveCase = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        if (!cards.length) {
          ticking = false;
          return;
        }
        const triggerY = window.innerHeight * 0.36;
        let nextActive = cards[0];

        for (const card of cards) {
          const rect = card.getBoundingClientRect();
          if (rect.top <= triggerY) nextActive = card;
        }

        setPinnedCase(nextActive);
        ticking = false;
      });
    };

    if (pin && pinTag && pinLink && cards[0]) {
      pinLink.textContent = cards[0].dataset.caseTitle || "";
      pinTag.textContent = cards[0].dataset.caseTags || `${cards[0].dataset.caseOrg} · ${cards[0].dataset.caseYear}`;
    }

    updateActiveCase();
    window.addEventListener("scroll", updateActiveCase, { passive: true });
    window.addEventListener("resize", updateActiveCase);
  </script>
</Base>

<style>
  .case-scroll {
    position: relative;
  }

  .case-pin {
    position: sticky;
    top: 69px;
    z-index: 5;
    margin: 0 0 22px;
    background: #fff;
    padding: 10px 0 14px;
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    transition: opacity 0.22s ease;
    pointer-events: none;
  }

  .case-pin-title {
    margin: 0;
    min-width: 0;
    pointer-events: auto;
  }

  .case-pin-title a {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  .case-pin-tag {
    margin: 0;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-size: 0.84rem;
    color: var(--muted);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .work-grid {
    gap: 28px;
  }

  .case-divider {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 16px;
    padding: 2px 0 10px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 14px;
  }

  .case-divider h3,
  .case-divider p {
    margin: 0;
  }

  .case-divider h3 {
    min-width: 0;
  }

  .case-divider h3 a {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .case-divider p {
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-size: 0.84rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .work-section {
    padding-top: 22px;
  }

  .work-section .section-title {
    margin-bottom: 24px;
  }

  .work-mosaic {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 10px;
    align-items: start;
  }

  .work-mosaic .placeholder {
    height: auto !important;
    border-radius: 0;
  }

  .tile-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    background: var(--surface);
  }

  .tile-item {
    width: 100%;
    height: auto;
    align-self: start;
    display: grid;
    gap: 4px;
  }

  .tile-media {
    width: 100%;
    height: auto;
    align-self: start;
  }

  .tile-label {
    margin: 0;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-size: 11px;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8a8a8a;
  }

  .speak-section {
    padding-top: 48px;
  }

  .speak-section .section-title {
    margin-bottom: 24px;
  }

  .speak-entry {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 32px;
    align-items: baseline;
    padding-top: 2px;
    border-top: 1px solid var(--line);
  }

  .speak-date {
    margin: 0;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8a8a8a;
  }

  .speak-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 400;
    max-width: 60ch;
    line-height: 1.45;
  }

  .reveal {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 700px) {
    .work-section {
      padding-top: 18px;
    }

    .work-section .section-title {
      margin-bottom: 18px;
    }

    .work-grid {
      gap: 20px;
    }

    .case-divider {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: baseline;
      gap: 4px;
      padding-bottom: 8px;
      margin-bottom: 10px;
    }

    .case-pin {
      display: none;
    }

    .work-mosaic {
      grid-template-columns: 1fr;
    }

    .tile-media {
   
      grid-column: auto;
    }

    .speak-entry {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }
</style>
